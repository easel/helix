[286.304296, "o", "\u001b[3m                                             Issues (4)                                             \u001b[0m\r\n\u001b[90m╭────────────────┬─────┬──────────┬─────────┬──────────────────────────────────────────────────────╮\u001b[0m\r\n\u001b[90m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mID            \u001b[0m\u001b[1m \u001b[0m\u001b[90m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m P \u001b[0m\u001b[1m \u001b[0m\u001b[90m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mStatus  \u001b[0m\u001b[1m \u001b[0m\u001b[90m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mType   \u001b[0m\u001b[1m \u001b[0m\u001b[90m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mTitle                                               \u001b[0m\u001b[1m \u001b[0m\u001b[90m│\u001b[0m\r\n\u001b[90m├────────────────┼─────┼──────────┼─────────┼──────────────────────────────────────────────────────┤\u001b[0m\r\n\u001b[90m│\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36mhello-helix-w6\u001b[0m\u001b[1;36m \u001b[0m\u001b[90m│\u001b[0m\u001b[31m \u001b[0m\u001b[31mP1 \u001b[0m\u001b[31m \u001b[0m\u001b[90m│\u001b[0m\u001b[90m \u001b[0m\u001b[90mclosed  \u001b[0m\u001b[90m \u001b[0m\u001b[90m│\u001b[0m\u001b[34m \u001b[0m\u001b[34mtask   \u001b[0m\u001b[34m \u001b[0m\u001b[90m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mImplement US-001: temperature conversion CLI        \u001b[0m\u001b[1m \u001b[0m\u001b[90m│\u001b[0m\r\n"]
[286.304542, "o", "\u001b[90m│\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36mi             \u001b[0m\u001b[1;36m \u001b[0m\u001b[90m│\u001b[0m\u001b[31m \u001b[0m\u001b[31m   \u001b[0m\u001b[31m \u001b[0m\u001b[90m│\u001b[0m\u001b[90m \u001b[0m\u001b[90m        \u001b[0m\u001b[90m \u001b[0m\u001b[90m│\u001b[0m\u001b[34m \u001b[0m\u001b[34m       \u001b[0m\u001b[34m \u001b[0m\u001b[90m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m                                                    \u001b[0m\u001b[1m \u001b[0m\u001b[90m│\u001b[0m\r\n\u001b[90m│\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36mhello-helix-pn\u001b[0m\u001b[1;36m \u001b[0m\u001b[90m│\u001b[0m\u001b[33m \u001b[0m\u001b[33mP2 \u001b[0m\u001b[33m \u001b[0m\u001b[90m│\u001b[0m\u001b[32m \u001b[0m\u001b[32mopen    \u001b[0m\u001b[32m \u001b[0m\u001b[90m│\u001b[0m\u001b[34m \u001b[0m\u001b[34mtask   \u001b[0m\u001b[34m \u001b[0m\u001b[90m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mAdd error-path tests (missing flag, bad input, both \u001b[0m\u001b[1m \u001b[0m\u001b[90m│\u001b[0m\r\n\u001b[90m│\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36mj             \u001b[0m\u001b[1;36m \u001b[0m\u001b[90m│\u001b[0m\u001b[33m \u001b[0m\u001b[33m   \u001b[0m\u001b[33m \u001b[0m\u001b[90m│\u001b[0m\u001b[32m \u001b[0m\u001b[32m        \u001b[0m\u001b[32m \u001b[0m\u001b[90m│\u001b[0m\u001b[34m \u001b[0m\u001b[34m       \u001b[0m\u001b[34m \u001b[0m\u001b[90m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mflags)                                              \u001b[0m\u001b[1m \u001b[0m\u001b[90m│\u001b[0m\r\n\u001b[90m│\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36mhello-helix-kx\u001b[0m\u001b[1;36m \u001b[0m\u001b[90m│\u001b[0m\u001b[33m \u001b[0m\u001b[33mP2 \u001b[0m\u001b[33m \u001b[0m\u001b[90m│\u001b[0m\u001b[32m \u001b[0m\u001b[32mopen    \u001b[0m\u001b[32m \u001b[0m\u001b[90m│\u001b[0m\u001b[34m \u001b[0m\u001b[34mtask   \u001b[0m\u001b[34m \u001b[0m\u001b[90m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mAdd CLI integration tests for AC-1 and AC-2         \u001b[0m