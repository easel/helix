[215.265278, "o", "── bin/convert.js ──\r\n"]
[215.266268, "o", "function toFahrenheit(c) {\r\n  return (c * 9/5) + 32;\r\n}\r\n\r\nfunction toCelsius(f) {\r\n  return (f - 32) * 5/9;\r\n}\r\n\r\nmodule.exports = { toFahrenheit, toCelsius };\r\n\r\n// CLI handling\r\nif (require.main === module) {\r\n  const args = process.argv.slice(2);\r\n  let flag = null;\r\n  let value = null;\r\n\r\n  for (let i = 0; i < args.length; i++) {\r\n    if (args[i] === '--to-celsius' || args[i] === '--to-fahrenheit') {\r\n      flag = args[i];\r\n      value = args[i + 1];\r\n      break;\r\n    }\r\n  }\r\n\r\n  if (!flag) {\r\n"]
