[91.17834, "o", "── docs/helix/01-frame/user-stories/US-001-temperature-conversion.md ──\r\n"]
[91.179495, "o", "# US-001: Temperature Conversion\r\n\r\n**As a** user,\r\n**I want to** convert temperatures between Fahrenheit and Celsius from the command line,\r\n**so that** I can quickly get accurate conversions without leaving my terminal.\r\n\r\n## Acceptance Criteria\r\n\r\n### AC-1: Fahrenheit to Celsius\r\n\r\n**Given** the user runs `convert --to-celsius 212`\r\n**Then** the output is `100.0`\r\n\r\n### AC-2: Celsius to Fahrenheit\r\n\r\n**Given** the user runs `convert --to-fahrenheit 0`\r\n**Then** the output is `32.0`\r\n"]
[91.179519, "o", "\r\n## References\r\n\r\n"]
[91.179704, "o", "...\r\n\r\n"]
[93.181016, "o", "\r\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n  Step 3: Create a technical design\r\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n\r\n"]
