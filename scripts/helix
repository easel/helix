#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -L "$source" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" && pwd
}

script_dir="$(resolve_script_dir)"
library_root="$(cd "$script_dir/.." && pwd)"
helix_docs_root="${HELIX_LIBRARY_ROOT:-$library_root/workflows}"
target_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Source built-in tracker
# shellcheck source=tracker.sh
source "$script_dir/tracker.sh"

agent="${HELIX_AGENT:-codex}"
review_every=5
max_cycles=0
auto_align=1
auto_review=1
dry_run=0
quiet=0

# Session log — all stderr is tee'd to this file for post-hoc inspection
helix_log_dir="${target_root}/.helix-logs"
mkdir -p "$helix_log_dir"
helix_log="${helix_log_dir}/helix-$(date +%Y%m%d-%H%M%S).log"
exec 3>&2
exec 2> >(tee -a "$helix_log" >&3)


usage() {
  cat <<EOF
Usage:
  helix run [--agent codex|claude] [--review-every N] [--max-cycles N] [--no-auto-align] [--no-auto-review] [--dry-run]
  helix implement [--agent codex|claude] [selector]
  helix check [--agent codex|claude] [scope]
  helix align [--agent codex|claude] [scope]
  helix backfill [--agent codex|claude] [scope]
  helix plan [--agent codex|claude] [--rounds N] [scope]
  helix polish [--agent codex|claude] [--rounds N] [scope]
  helix next
  helix review [--agent codex|claude] [scope]
  helix experiment [--agent codex|claude] [--close] [issue-id|goal]
  helix tracker <command> [args...]
  helix help

Commands:
  run         Loop over ready HELIX work, then check whether to continue
  implement   Run one bounded implementation pass
  check       Run the bounded HELIX queue-health check
  align       Run reconcile-alignment for a scope (default: repo)
  backfill    Run documentation backfill for a scope (default: repo)
  plan        Create a comprehensive design document through iterative refinement
  polish      Refine issues before implementation (dedup, coverage, criteria)
  next        Show recommended next issue
  review      Fresh-eyes review of recent work
  experiment  Run one experiment iteration for metric-driven optimization
  tracker     Built-in bead tracker (init, create, show, update, close, list, ready, blocked, dep, status, import, export)

Options:
  --agent           Agent to use: codex or claude (default: ${agent})
  --claude          Shorthand for --agent claude
  --codex           Shorthand for --agent codex
  --review-every    Run alignment every N completed implementation cycles
  --max-cycles      Stop after N completed implementation cycles
  --no-auto-align   Do not auto-run alignment when check returns ALIGN
  --no-auto-review  Do not run fresh-eyes review after each implementation
  --dry-run         Print the agent command instead of executing it
  --quiet, -q       Suppress progress output (command echo, prompt sizes)

Environment:
  HELIX_AGENT         Default agent (codex or claude)
  HELIX_AGENT_TIMEOUT Agent timeout in seconds (default: 900)
  HELIX_LIBRARY_ROOT  Override the library root that contains workflows/
  HELIX_TRACKER_DIR   Override the tracker directory (default: .helix/)

Logs:
  Session logs are written to .helix-logs/helix-YYYYMMDD-HHMMSS.log
  in the project root. All stderr output is captured for post-hoc inspection.

Notes:
  Codex runs as `codex --dangerously-bypass-approvals-and-sandbox exec --progress-cursor`.
EOF
}

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required command: $1" >&2
    exit 1
  fi
}

require_tracker() {
  need_cmd jq
  tracker_ensure
}

run_agent_prompt() {
  local prompt="$1"
  local prompt_bytes
  prompt_bytes="$(printf '%s' "$prompt" | wc -c)"
  local agent_timeout="${HELIX_AGENT_TIMEOUT:-900}"

  case "$agent" in
    codex)
      need_cmd codex
      if (( dry_run )); then
        printf 'codex --dangerously-bypass-approvals-and-sandbox exec --progress-cursor -C %q --ephemeral %q\n' "$target_root" "$prompt"
      else
        if (( ! quiet )); then
          printf 'helix: [%s] codex exec --progress-cursor -C %s --ephemeral <prompt %s bytes>\n' "$(date +%H:%M:%S)" "$target_root" "$prompt_bytes" >&2
        fi
        codex --dangerously-bypass-approvals-and-sandbox exec --progress-cursor -C "$target_root" --ephemeral "$prompt"
      fi
      ;;
    claude)
      need_cmd claude
      if (( dry_run )); then
        printf 'cd %q && claude -p --permission-mode bypassPermissions --dangerously-skip-permissions --no-session-persistence %q\n' "$target_root" "$prompt"
      else
        if (( ! quiet )); then
          printf 'helix: [%s] claude -p (timeout %ss)\n' "$(date +%H:%M:%S)" "$agent_timeout" >&2
          printf '%s\n' "$prompt" | sed 's/^/helix: │ /' >&2
          printf 'helix: └─ %s bytes\n' "$prompt_bytes" >&2
        fi

        local claude_pid
        if (( ! quiet )) && command -v jq >/dev/null 2>&1; then
          # Stream JSON mode: show live tool-call progress on stderr,
          # emit final text result on stdout.
          (cd "$target_root" && printf '%s' "$prompt" | claude -p \
            --permission-mode bypassPermissions \
            --dangerously-skip-permissions \
            --no-session-persistence \
            --output-format stream-json \
            --verbose \
          | while IFS= read -r line; do
              # Show tool calls with key details
              tool_info="$(printf '%s' "$line" | jq -r '
                select(.type == "assistant")
                | .message.content[]?
                | select(.type == "tool_use")
                | .name as $n
                | .input as $i
                | if $n == "Read" then "\($n)(\($i.file_path // "" | split("/") | last))"
                  elif $n == "Write" then "\($n)(\($i.file_path // "" | split("/") | last))"
                  elif $n == "Edit" then "\($n)(\($i.file_path // "" | split("/") | last))"
                  elif $n == "Glob" then "\($n)(\($i.pattern // ""))"
                  elif $n == "Grep" then "\($n)(\($i.pattern // ""))"
                  elif $n == "Bash" then "\($n)(\($i.command // "" | .[0:80]))"
                  elif $n == "Agent" then "\($n)(\($i.description // ""))"
                  elif $n == "Skill" then "\($n)(\($i.skill // ""))"
                  else $n
                  end
              ' 2>/dev/null || true)"
              if [[ -n "$tool_info" ]]; then
                printf 'helix: [%s] → %s\n' "$(date +%H:%M:%S)" "$tool_info" >&2
              fi
              # Show thinking/text progress
              think="$(printf '%s' "$line" | jq -r '
                select(.type == "assistant")
                | .message.content[]?
                | select(.type == "thinking")
                | .thinking // empty
                | .[0:500]
              ' 2>/dev/null || true)"
              if [[ -n "$think" ]]; then
                printf 'helix: [%s] 💭 %s\n' "$(date +%H:%M:%S)" "$think" >&2
              fi
              # Show tool result summaries (first line, truncated)
              tool_result="$(printf '%s' "$line" | jq -r '
                select(.type == "user")
                | .message.content[]?
                | select(.type == "tool_result")
                | .content // ""
                | if type == "array" then .[0].text // "" else . end
                | split("\n")[0]
                | .[0:120]
              ' 2>/dev/null || true)"
              if [[ -n "$tool_result" ]]; then
                local is_err
                is_err="$(printf '%s' "$line" | jq -r '
                  select(.type == "user")
                  | .message.content[]?
                  | select(.type == "tool_result")
                  | if .is_error then "!" else " " end
                ' 2>/dev/null || true)"
                printf 'helix: [%s]  %s %s\n' "$(date +%H:%M:%S)" "${is_err:-" "}" "$tool_result" >&2
              fi
              # Emit final result text to stdout
              result="$(printf '%s' "$line" | jq -r '
                select(.type == "result") | .result // empty
              ' 2>/dev/null || true)"
              if [[ -n "$result" ]]; then
                printf '%s\n' "$result"
              fi
            done) &
        else
          # Quiet / no jq: plain text mode
          (cd "$target_root" && printf '%s' "$prompt" | claude -p \
            --permission-mode bypassPermissions \
            --dangerously-skip-permissions \
            --no-session-persistence \
            --verbose) &
        fi
        claude_pid=$!

        # Watchdog: timeout
        local elapsed=0
        while kill -0 "$claude_pid" 2>/dev/null; do
          sleep 10
          elapsed=$((elapsed + 10))
          if (( elapsed >= agent_timeout )); then
            printf 'helix: [%s] agent timeout after %ss — killing\n' "$(date +%H:%M:%S)" "$elapsed" >&2
            kill "$claude_pid" 2>/dev/null
            wait "$claude_pid" 2>/dev/null
            return 1
          fi
        done
        wait "$claude_pid"
      fi
      ;;
    *)
      echo "unsupported agent: $agent" >&2
      exit 1
      ;;
  esac
}

inline_action() {
  local action_file="$1"
  printf 'Read and follow the action at %s.\n' "$action_file"
}

implementation_prompt() {
  local selector="${1:-}"
  cat <<EOF
Execute the following HELIX implementation action.
$(inline_action "${helix_docs_root}/actions/implementation.md")
Use supporting references at ${helix_docs_root}/README.md and ${helix_docs_root}/phases/04-build/enforcer.md as needed.
Execute in the current repository rooted at ${target_root}.
Issue tracker: built-in JSONL at ${tracker_file}. Use \`helix tracker ready --json\`, \`helix tracker show <id>\`, \`helix tracker update <id> --claim\`, \`helix tracker close <id>\`.
Concurrency rule: re-read the selected issue immediately before claim and immediately before close. If tracker metadata drifted materially, do not claim or close from stale assumptions; re-check instead.
${selector:+Implementation target: ${selector}.}
CRITICAL: If tests fail after your changes, fix them. 99% of test failures are caused by your changes, not by pre-existing breakage. Do not blame external causes, do not skip tests, do not commit with failing tests. Fix the code or fix the test. Retry up to 3 times before giving up. Never commit broken work.
Follow the action exactly. Do the work — do not just describe what you would do.
Session log: ${helix_log}
EOF
}

check_prompt() {
  local scope="${1:-repo}"
  cat <<EOF
Execute the following HELIX check action.
$(inline_action "${helix_docs_root}/actions/check.md")
Use supporting references at ${helix_docs_root}/README.md as needed.
Execute in the current repository rooted at ${target_root}.
Issue tracker: built-in JSONL at ${tracker_file}. Use \`helix tracker ready --json\`, \`helix tracker list --json\`, \`helix tracker blocked --json\`.
Review scope: ${scope}.
CRITICAL: Your output MUST contain the line "NEXT_ACTION: CODE" where CODE is one of IMPLEMENT, ALIGN, BACKFILL, WAIT, GUIDANCE, or STOP. This line must appear on its own, not inside a code block or backticks. Without this line the automation cannot continue. Output this line FIRST, before any other analysis.
Follow the action exactly. Do the work — do not just describe what you would do.
EOF
}

alignment_prompt() {
  local scope="${1:-repo}"
  cat <<EOF
Execute the following HELIX alignment action.
$(inline_action "${helix_docs_root}/actions/reconcile-alignment.md")
Use supporting references at ${helix_docs_root}/README.md and ${helix_docs_root}/templates/alignment-review.md as needed.
Execute in the current repository rooted at ${target_root}.
Issue tracker: built-in JSONL at ${tracker_file}. Use \`helix tracker\` subcommands.
Review scope: ${scope}.
Follow the action exactly. Do the work — do not just describe what you would do.
EOF
}

backfill_prompt() {
  local scope="${1:-repo}"
  cat <<EOF
Execute the following HELIX backfill action.
$(inline_action "${helix_docs_root}/actions/backfill-helix-docs.md")
Use supporting references at ${helix_docs_root}/README.md and ${helix_docs_root}/templates/backfill-report.md as needed.
Execute in the current repository rooted at ${target_root}.
Issue tracker: built-in JSONL at ${tracker_file}. Use \`helix tracker\` subcommands.
This is a writable live session: run real tracker commands, update docs/helix/, and do not claim that you need another session unless a concrete command actually fails.
Backfill scope: ${scope}.
Return the required BACKFILL_STATUS, BACKFILL_REPORT, and RESEARCH_EPIC trailer lines exactly.
Follow the action exactly. Do the work — do not just describe what you would do.
EOF
}

plan_prompt() {
  local scope="${1:-}"
  local rounds="${2:-5}"
  cat <<EOF
Execute the following HELIX plan action.
$(inline_action "${helix_docs_root}/actions/plan.md")
Use supporting references at ${helix_docs_root}/README.md and phase docs under ${helix_docs_root}/phases/ as needed.
Execute in the current repository rooted at ${target_root}.
Plan scope: ${scope:-repo}.
Refinement rounds: ${rounds}.
Follow the action exactly. Do the work — do not just describe what you would do.
EOF
}

polish_prompt() {
  local scope="${1:-}"
  local rounds="${2:-6}"
  cat <<EOF
Execute the following HELIX polish action.
$(inline_action "${helix_docs_root}/actions/polish.md")
Use supporting references at ${helix_docs_root}/README.md as needed.
Execute in the current repository rooted at ${target_root}.
Issue tracker: built-in JSONL at ${tracker_file}. Use \`helix tracker\` subcommands.
Polish scope: ${scope:-all open issues}.
Maximum refinement rounds: ${rounds}.
Follow the action exactly. Do the work — do not just describe what you would do.
EOF
}

review_prompt() {
  local scope="${1:-last-commit}"
  local in_loop="${2:-0}"
  cat <<EOF
Execute the following HELIX fresh-eyes review action.
$(inline_action "${helix_docs_root}/actions/fresh-eyes-review.md")
Execute in the current repository rooted at ${target_root}.
Issue tracker: built-in JSONL at ${tracker_file}. Use \`helix tracker\` subcommands.
Review scope: ${scope}.
${in_loop:+This review is running inside the automated helix run loop after an implementation cycle.}
Follow the action exactly. Do the work — do not just describe what you would do.
EOF
}

experiment_prompt() {
  local target="${1:-}"
  local close="${2:-0}"
  cat <<EOF
Execute the following HELIX experiment action.
$(inline_action "${helix_docs_root}/actions/experiment.md")
Use supporting references at ${helix_docs_root}/README.md and ${helix_docs_root}/ratchets.md as needed.
Execute in the current repository rooted at ${target_root}.
Issue tracker: built-in JSONL at ${tracker_file}. Use \`helix tracker\` subcommands.
Experiment target: ${target:-auto-select from ready phase:iterate issues}.
${close:+CLOSE SESSION: Execute Phase 3 (Session Close) — squash-merge the experiment branch, update ratchet floors, and close the issue. Do not run another iteration.}
Follow the action exactly. Do the work — do not just describe what you would do.
EOF
}

require_clean_worktree() {
  if ! (cd "$target_root" && git diff --quiet && git diff --cached --quiet); then
    echo "helix: worktree has uncommitted changes" >&2
    echo "helix: please commit your changes before starting an experiment" >&2
    echo "helix: experiment needs a clean worktree to safely branch and revert" >&2
    return 1
  fi
}

run_experiment() {
  local target="${1:-}"
  local close="${2:-0}"
  if (( ! dry_run )); then
    require_tracker
    require_clean_worktree
  fi
  run_agent_prompt "$(experiment_prompt "$target" "$close")"
}

helix_ready_count() {
  need_cmd jq
  tracker_ready --json | jq 'length'
}

extract_next_action() {
  local stripped
  # Strip markdown bold/backtick formatting but preserve underscores
  stripped="$(printf '%s\n' "$1" | sed 's/[*`]//g')"
  local result
  result="$(printf '%s\n' "$stripped" | grep -oE 'NEXT_ACTION: *(IMPLEMENT|ALIGN|BACKFILL|WAIT|GUIDANCE|STOP)' | head -n1 | sed 's/^NEXT_ACTION: *//')"
  printf '%s' "$result"
}

extract_backfill_status() {
  printf '%s\n' "$1" | grep -oE 'BACKFILL_STATUS: *(COMPLETE|GUIDANCE_NEEDED|BLOCKED)' | head -n1 | sed 's/^BACKFILL_STATUS: *//'
}

extract_backfill_report() {
  printf '%s\n' "$1" | grep -oE 'BACKFILL_REPORT: *[^ ]+' | head -n1 | sed 's/^BACKFILL_REPORT: *//'
}

extract_research_epic() {
  printf '%s\n' "$1" | grep -oE 'RESEARCH_EPIC: *[^ ]+' | head -n1 | sed 's/^RESEARCH_EPIC: *//'
}

parse_common_flags() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agent)
        agent="$2"
        shift 2
        ;;
      --claude)
        agent="claude"
        shift
        ;;
      --codex)
        agent="codex"
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --quiet|-q)
        quiet=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        break
        ;;
    esac
  done

  REMAINING_ARGS=("$@")
}

run_implementation() {
  local selector="${1:-}"
  if (( ! dry_run )); then
    require_tracker
  fi
  run_agent_prompt "$(implementation_prompt "$selector")"
}

run_check() {
  local scope="${1:-repo}"
  if (( ! dry_run )); then
    require_tracker
  fi
  run_agent_prompt "$(check_prompt "$scope")"
}

run_alignment() {
  local scope="${1:-repo}"
  if (( ! dry_run )); then
    require_tracker
  fi
  run_agent_prompt "$(alignment_prompt "$scope")"
}

run_backfill() {
  local scope="${1:-repo}"

  if (( dry_run )); then
    run_agent_prompt "$(backfill_prompt "$scope")"
    return 0
  fi

  require_tracker

  local output
  output="$(run_agent_prompt "$(backfill_prompt "$scope")")"
  printf '%s\n' "$output"

  local status
  status="$(extract_backfill_status "$output" || true)"
  if [[ -z "$status" ]]; then
    echo "helix: backfill output missing BACKFILL_STATUS trailer" >&2
    return 1
  fi

  local report
  report="$(extract_backfill_report "$output" || true)"
  if [[ -z "$report" ]]; then
    echo "helix: backfill output missing BACKFILL_REPORT trailer" >&2
    return 1
  fi

  if [[ ! -f "$target_root/$report" ]]; then
    echo "helix: declared backfill report does not exist: $report" >&2
    return 1
  fi

  local epic
  epic="$(extract_research_epic "$output" || true)"
  if [[ -n "$epic" ]]; then
    printf 'helix: research epic=%s\n' "$epic" >&2
  fi
  printf 'helix: backfill report=%s\n' "$report" >&2

  case "$status" in
    COMPLETE|GUIDANCE_NEEDED)
      return 0
      ;;
    BLOCKED)
      return 1
      ;;
    *)
      echo "helix: unknown BACKFILL_STATUS: $status" >&2
      return 1
      ;;
  esac
}

run_plan() {
  local scope="${1:-}"
  local rounds="${2:-5}"
  # Planning does NOT require tracker — it happens before issue creation
  run_agent_prompt "$(plan_prompt "$scope" "$rounds")"
}

run_polish() {
  local scope="${1:-}"
  local rounds="${2:-6}"
  if (( ! dry_run )); then
    require_tracker
  fi
  run_agent_prompt "$(polish_prompt "$scope" "$rounds")"
}

run_review() {
  local scope="${1:-last-commit}"
  local in_loop="${2:-0}"
  run_agent_prompt "$(review_prompt "$scope" "$in_loop")"
}

run_next() {
  require_tracker
  tracker_ready --json | jq -r '.[0].id // "no ready issues"'
}

recover_prompt() {
  local issue_id="$1"
  local issue_info="$2"
  local git_status="$3"
  local log_tail="$4"
  cat <<EOF
You are recovering from a crashed or timed-out HELIX implementation session.

Issue ${issue_id} is in_progress but the previous agent session ended without
closing it. Your job is to assess the partial work and either complete it
or revert it cleanly.

Read and follow the action at ${helix_docs_root}/actions/implementation.md.
Execute in the current repository rooted at ${target_root}.
Issue tracker: built-in JSONL at ${tracker_file}. Use \`helix tracker\` subcommands.

ISSUE STATE:
${issue_info}

GIT STATUS (uncommitted changes):
${git_status}

PREVIOUS SESSION LOG (last 50 lines):
${log_tail}

RECOVERY RULES:
1. If the worktree has uncommitted changes related to this issue:
   - Read the changed files and assess quality
   - If the work looks substantially complete: run tests, fix failures, commit, close the issue
   - If the work is broken or too incomplete: revert the changes with git checkout on the affected files, unclaim with helix tracker update <id> --status open
2. If the worktree is clean (no uncommitted changes):
   - The previous session either committed successfully or never started editing
   - Check if the issue's acceptance criteria are already met
   - If met: close with helix tracker close <id>
   - If not met: unclaim with helix tracker update <id> --status open so the next cycle picks it up fresh
3. CRITICAL: If tests fail after your changes, fix them. 99% of test failures are caused by your changes. Retry up to 3 times. Never commit broken work.

Do the work — do not just describe what you would do.
Session log: ${helix_log}
EOF
}

run_recovery() {
  local issue_id="$1"
  local issue_info="$2"
  local git_status="$3"
  local log_tail="$4"
  run_agent_prompt "$(recover_prompt "$issue_id" "$issue_info" "$git_status" "$log_tail")"
}

recover_orphaned_issues() {
  # Without claim freshness metadata, process absence is not enough evidence
  # to reclaim or revert work safely. Surface the ambiguity and leave state
  # intact rather than destroying unrelated local changes.
  local in_progress
  in_progress="$(tracker_list --status in_progress --label helix --json 2>/dev/null || echo '[]')"
  local count
  count="$(printf '%s' "$in_progress" | jq 'length' 2>/dev/null || echo 0)"

  if (( count == 0 )); then
    return 0
  fi

  printf 'helix: found %s in-progress issue(s), checking for orphans...\n' "$count" >&2

  local i
  for ((i = 0; i < count; i++)); do
    local issue_id
    issue_id="$(printf '%s' "$in_progress" | jq -r ".[$i].id" 2>/dev/null)"

    # Check if another helix process is already working on this issue
    if pgrep -f "helix.*implement.*${issue_id}" >/dev/null 2>&1; then
      printf 'helix: issue %s is being worked on by another process, skipping\n' "$issue_id" >&2
      continue
    fi

    local git_status
    git_status="$(cd "$target_root" && git diff --stat 2>/dev/null || echo "clean")"
    printf 'helix: issue %s may be stale, but no active process is not sufficient evidence to reclaim it\n' "$issue_id" >&2
    if [[ "$git_status" != "clean" && -n "$git_status" ]]; then
      printf 'helix: leaving local changes intact while issue %s remains claimed\n' "$issue_id" >&2
    fi
  done
}

run_loop() {
  local attempted_cycles=0
  local completed_cycles=0
  local post_drain_alignment_ran=0

  need_cmd jq
  require_tracker

  # Recover orphaned issues from crashed sessions before starting the loop
  recover_orphaned_issues

  while true; do
    local ready_count
    ready_count="$(helix_ready_count)"

    if (( ready_count > 0 )); then
      local attempt_number="$((attempted_cycles + 1))"
      local closed_before
      closed_before="$(tracker_list --status closed --json | jq 'length')"

      printf 'helix: ready=%s, cycle=%s\n' "$ready_count" "$attempt_number" >&2
      attempted_cycles=$((attempted_cycles + 1))
      if ! run_implementation; then
        printf 'helix: implementation failed during cycle %s (will not count toward completed cycles)\n' "$attempt_number" >&2
        sleep 5
        recover_orphaned_issues
      else
        local review_ok=1
        # Post-implementation review: catch bugs and capture learnings
        if (( auto_review )); then
          printf 'helix: post-implementation review after cycle %s\n' "$attempt_number" >&2
          if ! run_review last-commit 1; then
            printf 'helix: review failed after cycle %s (continuing)\n' "$attempt_number" >&2
            review_ok=0
          fi
        fi

        local closed_after
        closed_after="$(tracker_list --status closed --json | jq 'length')"
        if (( closed_after > closed_before )) && (( review_ok )); then
          completed_cycles=$((completed_cycles + 1))
        else
          printf 'helix: cycle %s did not complete a tracked issue; completed cycles remain %s\n' "$attempt_number" "$completed_cycles" >&2
        fi
      fi
      post_drain_alignment_ran=0

      if (( completed_cycles > 0 )) && (( review_every > 0 )) && (( completed_cycles % review_every == 0 )); then
        printf 'helix: periodic alignment after %s cycles\n' "$completed_cycles" >&2
        if ! run_alignment repo; then
          printf 'helix: periodic alignment failed after %s cycles\n' "$completed_cycles" >&2
          return 1
        fi
      fi

      if (( max_cycles > 0 )) && (( completed_cycles >= max_cycles )); then
        printf 'helix: reached max cycles (%s)\n' "$max_cycles" >&2
        return 0
      fi

      continue
    fi

    local check_output
    if ! check_output="$(run_check repo)"; then
      echo "helix: check failed after queue drain" >&2
      return 1
    fi
    printf '%s\n' "$check_output"

    local next_action
    next_action="$(extract_next_action "$check_output" || true)"

    case "$next_action" in
      IMPLEMENT)
        continue
        ;;
      ALIGN)
        if (( auto_align )) && (( post_drain_alignment_ran == 0 )); then
          printf 'helix: queue drained, running alignment\n' >&2
          if ! run_alignment repo; then
            echo "helix: post-drain alignment failed" >&2
            return 1
          fi
          post_drain_alignment_ran=1
          continue
        fi
        echo "helix: stopping after check returned ALIGN" >&2
        return 0
        ;;
      WAIT)
        printf 'helix: stopping after check returned WAIT\n' >&2
        return 0
        ;;
      BACKFILL)
        printf 'helix: stopping after check returned BACKFILL\n' >&2
        printf 'helix: run helix backfill repo\n' >&2
        return 0
        ;;
      GUIDANCE|STOP)
        printf 'helix: stopping after check returned %s\n' "$next_action" >&2
        return 0
        ;;
      *)
        echo "helix: unable to determine NEXT_ACTION from check output" >&2
        return 1
        ;;
    esac
  done
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    help|-h|--help)
      usage
      ;;
    run)
      parse_common_flags "$@"
      set -- "${REMAINING_ARGS[@]}"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --review-every)
            review_every="$2"
            shift 2
            ;;
          --max-cycles)
            max_cycles="$2"
            shift 2
            ;;
          --no-auto-align)
            auto_align=0
            shift
            ;;
          --no-auto-review)
            auto_review=0
            shift
            ;;
          *)
            echo "unknown option for run: $1" >&2
            exit 1
            ;;
        esac
      done

      run_loop
      ;;
    implement)
      parse_common_flags "$@"
      set -- "${REMAINING_ARGS[@]}"
      run_implementation "${1:-}"
      ;;
    check)
      parse_common_flags "$@"
      set -- "${REMAINING_ARGS[@]}"
      run_check "${1:-repo}"
      ;;
    align)
      parse_common_flags "$@"
      set -- "${REMAINING_ARGS[@]}"
      run_alignment "${1:-repo}"
      ;;
    backfill)
      parse_common_flags "$@"
      set -- "${REMAINING_ARGS[@]}"
      run_backfill "${1:-repo}"
      ;;
    plan)
      parse_common_flags "$@"
      set -- "${REMAINING_ARGS[@]}"
      local plan_rounds=5
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --rounds) plan_rounds="$2"; shift 2 ;;
          *) break ;;
        esac
      done
      run_plan "${1:-}" "$plan_rounds"
      ;;
    polish)
      parse_common_flags "$@"
      set -- "${REMAINING_ARGS[@]}"
      local polish_rounds=6
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --rounds) polish_rounds="$2"; shift 2 ;;
          *) break ;;
        esac
      done
      run_polish "${1:-}" "$polish_rounds"
      ;;
    next)
      parse_common_flags "$@"
      run_next
      ;;
    review)
      parse_common_flags "$@"
      set -- "${REMAINING_ARGS[@]}"
      run_review "${1:-last-commit}"
      ;;
    experiment)
      parse_common_flags "$@"
      set -- "${REMAINING_ARGS[@]}"
      local experiment_close=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --close) experiment_close=1; shift ;;
          *) break ;;
        esac
      done
      run_experiment "${1:-}" "$experiment_close"
      ;;
    tracker)
      parse_common_flags "$@"
      set -- "${REMAINING_ARGS[@]}"
      tracker_dispatch "$@"
      ;;
    *)
      echo "unknown command: $command" >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
