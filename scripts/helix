require_clean_worktree() {
  if ! (cd "$target_root" && git diff --quiet && git diff --cached --quiet); then
    summary_line "worktree has uncommitted changes"
    summary_line "please commit your changes before starting an experiment"
    summary_line "experiment needs a clean worktree to safely branch and revert"
    return 1
  fi
}

run_experiment() {
  local target="${1:-}"
  local close="${2:-0}"
  if (( ! dry_run )); then
    require_tracker
    require_clean_worktree
  fi
  run_agent_prompt "$(experiment_prompt "$target" "$close")"
}

