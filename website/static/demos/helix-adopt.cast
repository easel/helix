[7.292, "o", "\r\n  1. Frame mode \u2014 author vision, PRD, and feature specs from templates\r\n  2. Backfill mode \u2014 read your existing code/docs and propose an artifact graph\r\n"]
[7.392, "o", "\r\n\u001b[2m# That's adoption. One install, one ask. No CLI, no config dance.\u001b[0m\r\n"]
