[8.054, "o", "\u001b[2m  \u2699 Write(file_path='schema-mapping.yaml')\u001b[0m\r\n"]
[8.554, "o", "\u001b[2m  \u2192 3 payer mappings (acme, beta, gamma); strict KnownFields decoding\u001b[0m\r\n"]
[8.854, "o", "\u001b[2m  \u2699 Write(file_path='internal/ingest/header_sniffer.go')\u001b[0m\r\n"]
