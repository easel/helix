[10.154, "o", "\u001b[2m  \u2192 3 fixtures: acme exact-match \u00b7 beta case-insensitive + reordered \u00b7 unknown headers \u2192 error\u001b[0m\r\n"]
[10.454, "o", "\r\n\u001b[2m# The acceptance contract is the gate. Now run it.\u001b[0m\r\n"]
[11.054, "o", "\u001b[2m  \u2699 Bash(command='go test ./... && go vet ./...')\u001b[0m\r\n"]
[11.554, "o", "\u001b[2m  \u2192 ok  github.com/telepathdata/csv-ingest/tests  0.002s\r\nvet OK\u001b[0m\r\n"]
[11.854, "o", "\u001b[2m  \u2699 Bash(command='gosec -include=G201,G202,G203,G204 ./...')\u001b[0m\r\n"]
[12.354, "o", "\u001b[2m  \u2192 0 issues (OWASP A03 injection rules clean)\u001b[0m\r\n"]
