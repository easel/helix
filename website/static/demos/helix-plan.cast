[6.92, "o", "\r\n  bead-001  \u00b7 CSV header sniffer \u00b7 accepts: schema-mapping.yaml exists\r\n            \u00b7 evidence: tests/header_sniffer_test.go (3 fixtures)\r\n  bead-002  \u00b7 row-level validator \u00b7 accepts: rejects malformed rows with diagnostic\r\n            \u00b7 evidence: tests/validator_test.go (10 cases incl. unicode)\r\n  bead-003  \u00b7 Parquet writer \u00b7 accepts: round-trip equivalence on golden CSV\r\n            \u00b7 evidence: tests/parquet_test.go + benchmarks/throughput\r\n  bead-004  \u00b7 CLI surface \u00b7 accepts: --help, --schema, --output flags documented\r\n            \u00b7 evidence: e2e test against fixture/sample.csv\r\n"]
