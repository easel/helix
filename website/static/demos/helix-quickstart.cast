[198.500679, "o", "function toFahrenheit(c) {\r\n  return (c * 9 / 5) + 32;\r\n}\r\n\r\nfunction toCelsius(f) {\r\n  return (f - 32) * 5 / 9;\r\n}\r\n\r\nif (require.main === module) {\r\n  const args = process.argv.slice(2);\r\n  const toFFlag = args.indexOf('--to-fahrenheit');\r\n  const toCFlag = args.indexOf('--to-celsius');\r\n\r\n  if (toFFlag !== -1 && args[toFFlag + 1] !== undefined) {\r\n    const val = parseFloat(args[toFFlag + 1]);\r\n    if (isNaN(val)) {\r\n      process.stderr.write('Usage: node bin/convert.js --to-fahrenheit <value>\\n');\r\n      process.exit(1);\r\n    }\r\n    console.log(toFahrenheit(val).toFixed(1));\r\n"]
[198.500884, "o", "...\r\n\r\n"]
